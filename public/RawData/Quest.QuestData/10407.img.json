        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "I thought you were going to help me out. If I have to do this by myself, I'll have to get going fast. Please don't bother me now. See you around."
