  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Good timing. #p411# over in #m10003000# put in a request for a special item, but I’m short on the materials to make it. Think you could lend me a hand?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Alright. What I need are #b#t4000018#s#k. Has to be leather from those things—nothing else will do. What am I making, you ask? Heh, digging too deep into back-alley business can get dangerous. Let’s just keep that part a secret for now. Anyway, hurry it up."
        }
      },
      "no": {
        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "We’re partners, remember? You didn’t forget that already, did you?"
        }
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Nice! This is exactly what I needed. Glad I asked you to handle it."
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Here—this is for you. I’ll give you a #t2002008#. Use it and training your leatherworking skills should go a lot smoother."
        },
        "1": {
          "_dirName": "1",
          "_dirType": "String",
          "_value": "Though… this could be troublesome. Feels like #p411# is going to keep sending requests like this. Looks like I might be needing your help more often. Guess I’ll see you again soon. Heh…"
        }
      },
