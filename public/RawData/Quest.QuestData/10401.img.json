    "name": {
      "_dirName": "name",
      "_dirType": "String",
      "_value": "Building a New House For Blackbull"
    },
    "area": {
      "_dirName": "area",
      "_dirType": "Int",
      "_value": 15
    },
    "0": {
      "_dirName": "0",
      "_dirType": "String",
      "_value": "I heard that \"#p501#\" in #m10004000# is building a new house..."
    },
    "1": {
      "_dirName": "1",
      "_dirType": "String",
      "_value": "I ran into \"#p501#\" again, the guy whose house I helped fix. He was surprised at how strong I looked and asked me for a much harder favor. His cousins from #m10001000# are all trying to move to #m10004000#, so he needs to build a new house! To build a new house, he said he needed #b100 #t4000043#s, 30 #t4003000#s, 30 #t4003001#, and #t4001006##k. His son had the deed to the land, but it was stolen by #o31#s near #m10005000#... hmmm... I should be looking for those wandering around the deep forest..."
    },
    "2": {
      "_dirName": "2",
      "_dirType": "String",
      "_value": "So that all of \"#p501#'s\" cousins could move to #m10004000#, I got him the items he requested. It was really tough, and I hope he doesn't ask me to BUILD a house for him next time... "
    },
    "demandSummary": {
      "_dirName": "demandSummary",
      "_dirType": "String",
      "_value": "#t4000043# #b#c4000043##k / 100\\n#t4003000# #b#c4003000##k / 30\\n#t4003001# #b#c4003001##k / 30\\n#t4001006# #b#c4001006##k / 1"
    }
