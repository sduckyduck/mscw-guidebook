  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Traveler, you've returned... I've sealed the doll that you gave me deep in the dark forest. But the #o38#s are still increasing in numbers... Can you please bring me #b150 #t4000033#s#k?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Thank you so much. The #o38#s are often seen in the Dark Tree Forest near #m10002000#. Please take down #r150 #o38#s#k and bring me #b150#k #b#t4000033#s#k."
        }
      },
      "no": {
        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "I see... I thought I could count on you for this, but if you are busy, then it's understandable. Please come back if you ever have a change of heart in the near future."
        }
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "This is... Wow! You've brought me 150 #t4000033#s! That means you've thinned out the #o38#s. But it's too early to be relieved, because this doll is capable of continuously making new puppets."
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "Oh yeah, take this as a token of my appreciation. The fairies will spread word of your good deed. I personally think you deserve to be called a hero, and not just because you saved me from a pickle!"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "I have increased your fame a little. I am also giving you this scroll that I made myself based on what I've learned from #p313#. So long."
        }
      },
