      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "I'm glad you know the basic stuff around here. I'm just worried you might wander around and hunt stuff without knowing what you'll be facing. Well then, shall we get this started?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Alright, I'll explain more about this job. I need #b15 #t4000061#s#k for some coconut juice, #b30 #t4000032#s#k for the meals, and #b15 #t4000031#s#k for the dessert. Please get me the freshest materials available!"
        }
