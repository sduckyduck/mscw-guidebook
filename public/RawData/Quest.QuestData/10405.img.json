  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Hello, there, nice to meet you. I'm #b#p512##k the archeologist, and I'm looking for fossils of prehistoric life."
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "#m10004000# may be a land of dry, rocky mountains today, but it used to be a fertile land full of tall trees and lots of creatures, much like #m10002000#. Can you believe that? I'm looking for evidence from that era. If you are not busy and all, can you help me out?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Thank you. I ran into something odd yesterday. I went to Perion for some food, and when I came back, I found my tent raided by monsters. They took my fossils and ran away."
        },
        "1": {
          "_dirName": "1",
          "_dirType": "String",
          "_value": "Looking at the footprints, it seems like the culprits are #r#o13#s#k and #r#o15#s#k. Please go take care of them and gather up #b12 #t4031068#s#k and #b12 #t4031069#s#k for me. Thanks, and good luck!"
        }
      },
      "no": {
        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Kids these days are so selfish, saying no to an old man's favor. Fine, please leave."
        }
      }
    },
