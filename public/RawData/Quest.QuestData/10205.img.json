  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Traveler, you've returned... again. I'm sorry to keep asking you, but I need you to bring me more #t4000033#s. This is the last time, I promise. Can you bring me #b200 #t4000033#s#k?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Thank you so much. The #o38#s are often seen in the Dark Tree Forest near #m10002000#. Please take down #r200 #o38#s#k and bring me #b200 #t4000033#s#k."
        }
      },
      "no": {
        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "I see... I thought I could count on you for this, but if you are busy, then it's understandable. Please come back if you ever have a change of heart in the near future."
        }
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "This is... Wow! You've brought me 200 #t4000033#s! That means you've thinned out the #o38#s. But it's too early to be relieved, because this doll is capable of continuously making new puppets."
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "Oh yeah, take this as a token of my appreciation. The fairies will spread word of your good deed. I personally think you deserve to be called a hero, and not just because you saved me from a pickle!"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "I have increased your fame a little. I have also given you a hat made with fairy magic. Please put it to good use. Thank you so much for your help."
        },
        "1": {
          "_dirName": "1",
          "_dirType": "String",
          "_value": "Maybe fairies are unfairly prejudiced against humans. I'm confident that you'll protect this forest for all of us. Well then, so long..."
        }
      },
      "stop": {
        "_dirName": "stop",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "sub"
        },
        "mob": {
          "_dirName": "mob",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "Don’t forget to defeat the #r#o38#s#k as well."
          }
        },
        "item": {
          "_dirName": "item",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "So, you weren't able to collect #b200 #t4000033#s#k yet. The #t4000033# is making more Puppets of itself as we speak. You need to hurry up and bring me the dolls."
          }
        }
      }
    }
