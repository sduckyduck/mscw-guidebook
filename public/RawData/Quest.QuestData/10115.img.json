      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Hey, you're the one who gave me the medicine! I'm feeling much better now, thanks to you. And you look good, too. You look strong, perhaps even stronger than #p0000221#! Hehe, just kidding."
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
