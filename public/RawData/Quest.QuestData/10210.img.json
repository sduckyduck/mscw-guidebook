  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Hey there, human! Do you have any time on your hands? If not, then oh well... I have something to ask you... well, not really ask, but I have a favor to ask. Are you interested...?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "There's this teacher in my Magic School that scares the daylights out of everyone. I mean, he's as scary as they come. Anyway, he gave us homework to make a potion, but I'm swamped with so much homework from other classes that I don't know if I can do it."
        },
        "1": {
          "_dirName": "1",
          "_dirType": "String",
          "_value": "I need #b10 #t4000011#s, 10 #t4000006#s, and 3 #t4000007#s.#k Please get me those immediately!"
        },
        "2": {
          "_dirName": "2",
          "_dirType": "String",
          "_value": "What's the potion going to be used for? That's none of your business. Know this, though. If you get me the ingredients, I will reward you well for your effort. I can't stand owing anything to a human."
        }
      },
      "no": {
        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Fine, I don't care! I can always find someone else!"
        }
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Oh you got them all! I need to make this potion fast and get on with my other homework. I think I can finish my homework thanks to you. Here are some potions and scrolls I made earlier. I don't need them, so you should take them."
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "I don't need you now, so please leave!"
        }
      },
      "stop": {
        "_dirName": "stop",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "sub"
        },
        "item": {
          "_dirName": "item",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "I don't think you've gathered them all up. Hurry up, I don't have much time. I have to start memorizing spells after I'm done with the potion homework!"
          }
        }
      }
