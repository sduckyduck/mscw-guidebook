  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Hey there, kid. Yes, you! I am a scientist that specializes in the field of monsters and animals in this world. If you have any time available, would you mind helping this old man out?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Thank you. I have been studying the mushroom monsters, and... speaking of mushroom monsters, this reminds me of something."
        },
        "1": {
          "_dirName": "1",
          "_dirType": "String",
          "_value": "Years ago, my daughter and I went out of town in search of research materials. While we were busy excavating, we were ambushed by an enormous mushroom monster."
        },
        "2": {
          "_dirName": "2",
          "_dirType": "String",
          "_value": "By the time I regained consciousness, I had been severely battered and bruised, while my daughter was nowhere to be found. Ever since the incident, I have been studying mushroom monsters in hopes of finding some clues of my daughter's whereabouts."
        },
        "3": {
          "_dirName": "3",
          "_dirType": "String",
          "_value": "Oh, I'm rambling on again. Anyway, I would appreciate it a great deal if you can hunt #r20 #o4#s and #o9#s#k and get me #b10 #t4000003#s and 10 #t4000009#s#k. Thank you!"
        }
      },
      "no": {
        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "I would appreciate a good deal if you could help me out, but alas, if you're busy..."
        }
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "You brought everything! Thank you, thank you! I shall start studying these samples carefully. Oh, I almost forgot to reward you for your hard work."
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Here's a small gift to you. This should help you on your journey. I'll see you around."
        }
      },
