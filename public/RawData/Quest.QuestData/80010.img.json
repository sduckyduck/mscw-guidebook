      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Good timing! #p511# of #m10004000# has requested a special piece of armor for the town’s warriors, but I’m short on the materials needed to craft it. Could you help me out?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Thanks! I need a #b#t4010102##k for the armor. Please go defeat #r#o14#s#k in the #m10003000# region and bring some back for me. I’ll be waiting!"
        }
      },
      "no": {
        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "An apprentice refusing a master’s request… back in my day, that would’ve been unthinkable…"
        }
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Perfect! This is exactly what I needed. You really are a reliable apprentice! "
      },
      "yes": {
