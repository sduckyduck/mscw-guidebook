  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Huh… you’re already ready? You really are impatient… Don’t rush so much! This is the last one~! Alright then~ this time, can you take down #r#o37#s and #o45#s#k and bring me #b30 #t4000034#s, 10 #t4000050#s, and 1 #t4020107##k? I’m counting on you!"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Thanks so much! This time, you’ll probably need to look around the deep parts of the Ant Tunnel. When you get all those items, please bring them to me. I’ll be waiting right here!"
        }
      },
      "no": {
        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Yeah... You can't take a request from a kid... yeah... right... If you change your mind, please let me know... I can't do this on my own..."
        }
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Wow you collected them all! Great! This one was harder than last time, right? What? It is nothing? Haha... Anyway I will give these to the fairies. That should be about everything."
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "I got all the things you brought! Thanks sooo much for everything. You must’ve been annoyed, but you didn’t complain even once… you’re amazing! As a reward, the fairies in the forest near #m10002000# gave me this weird paper. But um… I don’t really know what it is."
        },
        "1": {
          "_dirName": "1",
          "_dirType": "String",
          "_value": "It kinda looks like it has some sort of magic power… but it’s too hard, so I don’t really get it… Anyway, I think it’s something you might need, so take it and use it well. I hope it helps! See you later!"
        }
      },
      "stop": {
        "_dirName": "stop",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "sub"
        },
        "mob": {
          "_dirName": "mob",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "Don’t forget to take down the monsters, too!"
          }
        },
        "item": {
          "_dirName": "item",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "It looks like you still haven’t gathered everything I asked for yet, huh? But keep it up! It may be tough, but if you help me out this last time, I’ll give you something really nice!"
          }
        }
      }
    }
