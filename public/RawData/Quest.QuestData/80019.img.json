    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Perfect timing. #p221# of #m10001000# mentioned she received a request from #m10004000# for a special item. I’m afraid I can’t finish it on my own in time. Would you be able to help me?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Thank you! What I need is #b#t4003001##k. It seems there aren't any carpenters in #m10004000#, after all. You should be able to find #r#o15#s#k around #m10004000#, so it shouldn’t be too difficult. I’ll be looking forward to it."
        }
      },
      "no": {
        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "You haven’t forgotten that I’m your mentor… have you?"
        }
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Great! This is exactly what I needed. I’m really glad I asked you for help."
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Here, as a reward, please take this #t2002006#. Using it should make training your woodworking skills a bit easier."
        },
        "1": {
          "_dirName": "1",
          "_dirType": "String",
          "_value": "But this is a bit of a problem… I have a feeling #p221# will keep sending requests like this. It seems I may be relying on your help even more. I’ll ask you again next time!"
