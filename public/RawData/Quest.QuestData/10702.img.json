      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Alright, the visitors that are coming this time are quite something. They only want the specials, and #t4000032#s alone will not do. Because of that, I'll need #b30 #t4000061#s#k for the coconut juice, #b60 #t4000032#s and 60 #t4000040#s#k for the main course, and #b30 #t4000031#s#k for the desert."
        }
      },
