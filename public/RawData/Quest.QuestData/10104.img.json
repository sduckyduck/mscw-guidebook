  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Whew... I had the most difficult time when I ran into a #o16# the other day. It was so frustrating! If only I had more strength... I would've showed them what for!"
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "Whoa! You look pretty strong! How about you take care of those bullies for me? Bring me #b20 #t4000013#s and 10 #t4000016#s#k as proof, and I'll give you something in return... Something really sweet! Yeah!"
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "HEY! In your hand... Those are the #b#t4000013#s#k and #b#t4000016#s#k I asked for? You got so many! Thank you! I feel soo much better. Muahaha, take that, mushrooms. Right back at ya, punks!"
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "Oh yeah. This isn't much, but take it. Great work!"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "This scroll... I believe it can strengthen your helmet. It's easy to use, too. Just open the Use tab of your Item Inventory and open your Equipment Inventory at the same time, then drag the scroll onto your helmet. There's a chance the scroll can fail, but life's risky like that..."
        }
      },
