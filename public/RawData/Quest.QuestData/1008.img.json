        "npc": {
          "_dirName": "npc",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "You didn't deliver my reply to #b#p10##k yet? If you lose my reply, just tell me. I suppose I can write up another one."
          }
        },
        "item": {
          "_dirName": "item",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "Have you not gone to the Chief yet? Or did you lose the letter? Please deliver the letter soon and bring back Chief #b#p17##'s reply."
          }
        }
      },
