        "item": {
          "_dirName": "item",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "If you can just bring me #b15 #t4000016#s and 15 #t4000019#s#k, I'll finally be able to start traveling... I'm begging you."
          }
