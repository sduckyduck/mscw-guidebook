  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Since you’re here, could you do me a small favor? I’ve been collecting all sorts of items lately — I think I might be able to create something new with them! So, could you gather some monster drops for me? It shouldn’t be too hard!"
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "Could you bring me #b50 #t4000043#s, 50 #t4000044#s, and 1 #t4020107##k, please?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Thank you so much! You can find what you need at the Golem’s Temple on the way from #m10001000# to the Dungeon. Once you’ve gathered everything, please come back and find me — I’ll be waiting for you right here."
        }
      },
      "no": {
        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Oh you must be really busy now... But please get back to me if you have time later. I would like to get the stuff by myself, but I am not fully recovered..."
        }
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Wow! You got them all! This one was little bit harder than the last one, right? But nothing will be hard for you... Anyway, thank you for collecting all of those items. Now, I have everything I need."
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "I’ve received all the items you collected. Thank you so much — you must have gone through a lot of trouble, yet you never once complained. As a token of my gratitude, I’d like to give you a cape that was tucked away deep inside our family chest. It was something my grandmother made long ago for #p221#, but the great war ended before she ever got to deliver it... Still, I’d like you to have it. Please treasure it well!"
        }
      },
