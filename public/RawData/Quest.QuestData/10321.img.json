      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Oh you're back!! Did you meet up with #p309#? What about the pill? The pill! Did you bring it?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Wow, this is it. This pill will enable me to fly anywhere I desire and finally realize my dream. Thank you so much for all your help. Here's a little thank you present from me. Hopefully it'll help you down the road. I'll see you around!"
        }
      },
