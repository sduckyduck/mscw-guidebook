  "QuestInfo": {
    "_dirName": "QuestInfo",
    "_dirType": "sub",
    "name": {
      "_dirName": "name",
      "_dirType": "String",
      "_value": "Taking Out the Alligators 1"
    },
    "parent": {
      "_dirName": "parent",
      "_dirType": "String",
      "_value": "The Alligators at the Swamp"
    },
    "area": {
      "_dirName": "area",
      "_dirType": "Int",
      "_value": 15
    },
    "0": {
      "_dirName": "0",
      "_dirType": "String",
      "_value": "I heard something happened to the tribespeople of #m10004000#. I should go ask #p506# about this."
    },
    "1": {
      "_dirName": "1",
      "_dirType": "String",
      "_value": "I met up with #p506# in #m10004000#. She told me that a few days ago, a group of tribespeople went hunting in the swamp and wound up being ambushed by a group of alligators. She was worried about the sudden surge of alligators taking over the swamp and asked me to reduce their numbers before they spawn out of control. I'll have to kill #r100 #o29#s and 40 #o18#s#k and pick up #b20 #t4000018#s#k along the way."
    },
    "2": {
      "_dirName": "2",
      "_dirType": "String",
      "_value": "The tribespeople of #m10004000# got ambushed by the alligator herd at the swamp, so #p506# asked if I could help take care of the alligators. I responded by taking out 100 #o29#s and 40 #o18#s. Hopefully this will bring some peace back to the swamp."
    },
    "demandSummary": {
      "_dirName": "demandSummary",
      "_dirType": "String",
      "_value": "#o18# #a104121#\\n#o29# #a104122#\\n#i4000018# #t4000018# #c4000018# / 20"
    }
  },
