    "text": {
      "_dirName": "text",
      "_dirType": "String",
      "_value": "   My dearest Stump,\\r \\rThe pain! Oh, the pain! I can't stand the pain of being away from you another moment! I need to feel your rough bark against my skin. I need to smell your thick, pine-fresh scent around me. Nothing can put out the flame I have for you... but I won't burn you! Promise!"
    }
