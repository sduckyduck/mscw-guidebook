        },
        "item": {
          "_dirName": "item",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "I see you still haven't gathered the materials that #b#p410##k requested. He needs you to hunt #b40 #o18#s#k and #b40 #o19#s#k, and collect #b20 #t4000018#s#k and #b20 #t4000019#s#k in order to conduct the research for a new potion. Just bring everything to me once you're done. You got this!"
          }
        },
        "mob": {
          "_dirName": "mob",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "You didn’t forget that part of his request was to hunt #r40 #o18#s and 40 #o19#s#k, right?"
          }
        }
      }
