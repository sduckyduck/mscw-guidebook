      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Thank you!!! We can finally use this medicine properly now. It seems that #b#p207##k from #b#m10001000##k has fallen ill again. If you bring this medicine to her, it should help ease her condition a little..."
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Darn... my whole body's aching... what, oh my... isn't that #b#t4031009##k?? How did you get it?? Wow, you must be amazing."
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "Um... is it okay if I take that medicine? I'll give you something that I don't really need... I urge you... please... I need that medicine..."
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Thank you so much... this may cure my longtime sickness after all... here's something I don't really need... hopefully it'll help you through your journey... here are some mesos too, as a sign of my appreciation..."
        }
