          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "You haven't met my father yet? He's the chief of #m10001000#. Please convince him to let me return home. And as a sign of proof, please get the #t4031006# my mother left behind..."
          }
        }
      },
