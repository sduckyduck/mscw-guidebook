        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Is it because I'm asking you for too much? Just remember, you'll be paid accordingly... if you feel like doing it, please come talk to me."
        }
      }
