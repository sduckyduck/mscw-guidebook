  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Just in time. I got work for you. You know #b#p408##k from the weapon store? He's got an enormous appetite, and not just for any old food, but EXOTIC food."
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "There's this one dish that you couldn't pay other people to eat, but somehow, it's his favorite dish. It's called Evil Eye Tail Stew. Just thinking about it makes me want to heave. Ugh. But he craves that stuff like there's no tomorrow."
      },
      "2": {
        "_dirName": "2",
        "_dirType": "String",
        "_value": "But he ran out of the main ingredient, #b#t4000022#s#k. He says #b30 #t4000022#s#k, after hunting #b50 #o23#s#k, should be enough to keep him fed for a long time... That shouldn’t be too hard for someone like you. Come see me after you have collected everything."
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Great work deserves great rewards. #b#p408##k is giving you a pair of shoes. May they take you far."
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Thank you so much for helping so many people with their requests. For now, it seems like no one else needs help. You're a friend to everyone here in #m10003000# now!"
        }
      },
      "stop": {
        "_dirName": "stop",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "sub"
        },
        "item": {
          "_dirName": "item",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "I see you still haven't gathered the materials that #b#p408##k requested. He needs #b30 #t4000022#s#k in order to create his favorite stir-fried dish. Just bring everything to me. Good luck!"
          }
        },
        "mob": {
          "_dirName": "mob",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "You didn’t forget that part of his request was to hunt #b50 #o23#s#k, right?"
          }
        }
      }
    }
