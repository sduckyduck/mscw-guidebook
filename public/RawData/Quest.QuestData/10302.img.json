  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "It's a special watch. Make sure you don't lose it. #p402# is in #m10003000#, right? Please... please take care of this and... and him. So long."
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "What? You convinced my father to let me return? That's unbelievable... I'm amazed that you changed the mind of Mr. Holier-Than-Thou. Now I can say goodbye to the life of a wanderer. Thank you so much!"
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "Whoa, this #t4031006# is... it's my mother's, for sure. I should have been better to her when she was alive... Anyway, you did me a huge favor, so here! It isn't much, but take it."
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "I got this earring from friends I met while traveling all around the island. Might as well look good traveling, right? Hehe... Hopefully it'll help you on your journey."
        }
      },
      "stop": {
        "_dirName": "stop",
        "_dirType": "sub",
