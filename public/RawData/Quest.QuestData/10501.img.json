  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Ah... you want this red book, huh?? I see... my daddy likes this book more than he likes me! This book... NO, I can't give you this book!! (stomach growling...) Ahhhh!"
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "No... no... I'm NOT hungry...! Dang... al-alright. I'll give you back the book. BUT! Not for free! I'm starving, and I need some food, so... if you get me something to eat, the book is yours. I promise!"
      },
      "2": {
        "_dirName": "2",
        "_dirType": "String",
        "_value": "I want to eat #b30 #t4000031#s#k. How can I eat that many, you ask? Don’t worry about that."
      },
      "3": {
        "_dirName": "3",
        "_dirType": "String",
        "_value": "If you ever get hungry on the way back and eat a couple of those... my dad's book is going to the #o31#s, so you better take care of that food!!!"
      }
    },
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Wow! That’s #b30 #t4000031#s#k, just like I asked for! Let’s see… maybe I’ll try one right now!"
      },
