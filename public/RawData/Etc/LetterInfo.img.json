    "text": {
      "_dirName": "text",
      "_dirType": "String",
      "_value": "My fuzzy little Lupin,\\r \\rEver since we shared that first banana, you've been monkeying around in my thoughts. I've gone ape for you, my charming capuchin. I've got a barrel full of kisses for you the next time we're together!"
    }
