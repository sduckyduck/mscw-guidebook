  "Say": {
    "_dirName": "Say",
    "_dirType": "sub",
    "1": {
      "_dirName": "1",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "Who are you? Whoa, isn't that the marble that #p204# so preciously takes care of? How did you get that??? What? #p204# asked you to get me that for my birthday? Wow, that's just awesome. This is a very precious item, you know. Now that the farming is almost done, I may have to go see #p204# to say thanks."
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Thanks for delivering #p204#'s present to me. Did you get my reward? Hopefully it'll help you on your journey."
        }
      },
      "stop": {
        "_dirName": "stop",
        "_dirType": "sub",
        "npc": {
          "_dirName": "npc",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "Oh, that crystal... did you not see #p225# yet? Please get him the present before his birthday passes. Did you lose your way to #m10001082# by any chance?"
          },
          "1": {
            "_dirName": "1",
            "_dirType": "String",
            "_value": "Head to #m10001080# and you'll see an entrance to #m10001082#. Avoid the #o92#s and traps and navigate your way through the hidden paths, and you'll find him."
          }
        },
        "item": {
          "_dirName": "item",
          "_dirType": "sub",
          "0": {
            "_dirName": "0",
            "_dirType": "String",
            "_value": "Who are you? This is our farm, and we raise a bunch of #o92#s. They are much stronger than the #o10#s that are raised out in the wild. Anyway, how can I help you?"
          }
        },
        "0": {
          "_dirName": "0",
          "_dirType": "sub"
        }
      },
      "lost": {
        "_dirName": "lost",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Ah, did you lose the marble that I gave you by any chance? Someone picked it up from the streets a couple of minutes ago. This is something I really cherish, so please take good care of it, and get it to #p225# ASAP."
        },
        "yes": {
          "_dirName": "yes",
          "_dirType": "sub"
        }
      }
    },
    "0": {
      "_dirName": "0",
      "_dirType": "sub",
      "0": {
        "_dirName": "0",
        "_dirType": "String",
        "_value": "My friend #b#p225##k grew up with me and has a birthday coming up in a few days. So, I've decided my gift will be my precious #b#t4031008##k."
      },
      "1": {
        "_dirName": "1",
        "_dirType": "String",
        "_value": "There's a problem, though. #p225# hasn't been coming uptown lately, probably because he's been swarmed with work. I'd like to go there and give it to him myself, but the #o92#s that he raises scare me to death. Well... if you have any time, can you get this marble to #p225# for me?"
      },
      "yes": {
        "_dirName": "yes",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Really? Thank you, thank you so much! Here's the marble. I even carved a message for #p225# on it. You can get to Utah's farm through #m010001080#. Good luck! "
        }
      },
      "no": {
        "_dirName": "no",
        "_dirType": "sub",
        "0": {
          "_dirName": "0",
          "_dirType": "String",
          "_value": "Oh, I see. Sorry for asking. You must be a very busy person... #p225# might be disappointed... sigh... what should I do now??"
        }
      }
    }
  }
